TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VK_USER_TOKEN=
VK_CHAT_PEER_ID=

# Защита панели оператора (/operator)
# OPERATOR_LOGIN — логин оператора (текст)
# OPERATOR_PASSWORD_HASH — bcrypt-хеш пароля.
#   Генерация: node scripts/generate-password-hash.mjs "ваш-пароль"
# JWT_SECRET — секрет для подписи JWT (минимум 32 байта).
#   Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   или: openssl rand -hex 32
OPERATOR_LOGIN=
OPERATOR_PASSWORD_HASH=
JWT_SECRET=
